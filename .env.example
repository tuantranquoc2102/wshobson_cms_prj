# PostgreSQL connection (matches docker-compose.yml)
DATABASE_URL="postgresql://cms:cms@example.comhost:5432/cms?schema=public"

# JWT signing secret for HS256 access tokens. MUST be >= 32 random bytes.
# Generate one with: openssl rand -hex 32
JWT_ACCESS_SECRET="replace-me-with-a-32-byte-random-secret-string"

# Shared secret for the scheduled-publish cron endpoint.
CRON_SECRET="replace-me-with-a-random-cron-secret"

# Node env: development | production | test
NODE_ENV="development"

# Set to "1" only when the app sits behind a trusted reverse proxy that
# populates X-Forwarded-For. Leave at "0" for direct local dev so rate-limit
# bucketing uses the real socket address.
TRUST_PROXY=0

# Optional pino log level override: trace | debug | info | warn | error | fatal
# LOG_LEVEL="debug"

# Seed credentials (used by prisma/seed.ts)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="admin1234"
